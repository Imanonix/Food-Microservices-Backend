  },
  "ReverseProxy": {
    "Routes": {
      "identity_route": {
        "ClusterId": "identity_cluster",
        "Match": {
          "Path": "/auth/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/auth" }
        ]
        
      },
      "catalog_route": {
        "ClusterId": "catalog_cluster",
        "Match": {
          "Path": "/catalog/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/catalog" }
        ]
      },
      "basket_route": {
        "ClusterId": "basket_cluster",
        //"AuthorizationPolicy": "AuthenticatedUser",
        "RateLimiterPolicy": "ratelimiter-policy",
        "Match": {
          "Path": "/basket/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/basket" }
        ]
      }
    },
    "Clusters": {
      "identity_cluster": {
        "Destinations": {
          "destination1": { "Address": "http://localhost:5101" }
        }
      },
      "catalog_cluster": {
        "Destinations": {
          "destination1": { "Address": "http://localhost:5102" }
        }
      },
      "basket_cluster": {
        "Destinations": {
          "destination1": { "Address": "http://localhost:5104" }
        }
      }
    }
  }
}
